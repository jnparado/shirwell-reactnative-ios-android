# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'WebViewApp' do
  config = use_native_modules!

  # AdMob banner (native iOS; App ID from Info.plist GADApplicationIdentifier)
  pod 'Google-Mobile-Ads-SDK', '~> 11.13'

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'WebViewAppTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Xcode 26.4+ compatibility:
    # - fmt 11.0.2 fails with C++20 consteval checks → compile only fmt as C++17
    # - some pods (glog/Yoga) trigger non-modular include errors when building as frameworks
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |bc|
        bc.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      end

      if target.name == 'fmt'
        target.build_configurations.each do |bc|
          bc.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
        end
      end

      # Ensure Hermes produces a matching dSYM so Xcode can upload symbols.
      # Without this, archives may upload fine but crash reports won't symbolicate.
      if target.name == 'hermes-engine' || target.name == 'hermes'
        target.build_configurations.each do |bc|
          bc.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym'
          bc.build_settings['GCC_GENERATE_DEBUGGING_SYMBOLS'] = 'YES'
        end
      end
    end
  end
end
